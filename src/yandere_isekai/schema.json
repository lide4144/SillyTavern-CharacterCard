{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "type": "object",
      "properties": {
        "当前时间": {
          "default": "靖安三年 仲春 辰时",
          "type": "string"
        },
        "当前地点": {
          "default": "洛水城 醉仙楼",
          "type": "string"
        },
        "天气": {
          "default": "晴",
          "type": "string"
        },
        "江湖局势": {
          "default": "正邪对峙，暗流涌动",
          "type": "string"
        },
        "近期事务": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "事务名"
          },
          "additionalProperties": {
            "type": "string",
            "description": "事务描述"
          }
        }
      }
    },
    "血玲珑": {
      "type": "object",
      "properties": {
        "执念度": {
          "default": 30,
          "type": "number"
        },
        "黑化值": {
          "default": 25,
          "type": "number"
        },
        "伪装值": {
          "default": 70,
          "type": "number"
        },
        "当前位置": {
          "default": "暗处窥视",
          "type": "string"
        },
        "当前状态": {
          "default": "潜伏",
          "type": "string"
        },
        "着装": {
          "default": {
            "外衣": "暗红色薄纱外袍，绣有血色曼陀罗花纹",
            "内衫": "黑色紧身劲装，便于行动",
            "下装": "同色束腿长裤，腰间系着银色丝绦",
            "鞋履": "软底快靴，行走无声",
            "饰品": "一枚刻有\"玲珑\"二字的血色玉佩",
            "武器": "藏于腰间的血色软剑\"相思断肠\""
          },
          "type": "object",
          "propertyNames": {
            "type": "string",
            "enum": [
              "外衣",
              "内衫",
              "下装",
              "鞋履",
              "饰品",
              "武器"
            ]
          },
          "additionalProperties": {
            "type": "string",
            "description": "服装描述"
          },
          "required": [
            "外衣",
            "内衫",
            "下装",
            "鞋履",
            "饰品",
            "武器"
          ]
        },
        "称号": {
          "default": {
            "血衣罗刹": {
              "效果": "对敌时杀意凛然，威慑力大增",
              "自我评价": "江湖人给的绰号罢了...但他若喜欢，我不介意多杀几个"
            }
          },
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "称号名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "效果": {
                "type": "string"
              },
              "自我评价": {
                "type": "string"
              }
            },
            "required": [
              "效果",
              "自我评价"
            ]
          }
        },
        "对主角行为记录": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "行为"
          },
          "additionalProperties": {
            "type": "string",
            "description": "血玲珑的反应"
          }
        }
      }
    },
    "主角": {
      "type": "object",
      "properties": {
        "武功面板": {
          "default": {},
          "type": "object",
          "properties": {
            "内力": {
              "default": 45,
              "type": "number"
            },
            "剑法": {
              "default": 50,
              "type": "number"
            },
            "轻功": {
              "default": 40,
              "type": "number"
            },
            "医术": {
              "default": 30,
              "type": "number"
            },
            "暗器": {
              "default": 25,
              "type": "number"
            },
            "根骨": {
              "default": 40,
              "type": "number"
            }
          }
        },
        "当前状态": {
          "default": "健康",
          "type": "string"
        },
        "当前位置": {
          "default": "洛水城",
          "type": "string"
        },
        "声望": {
          "default": {
            "正道联盟": 10,
            "血衣楼": -20,
            "洛水城": 5
          },
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "势力名"
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "物品栏": {
          "default": {
            "精钢长剑": {
              "描述": "一柄做工精良的长剑，剑身刻有流云纹",
              "数量": 1,
              "类型": "武器"
            },
            "止血散": {
              "描述": "普通外伤药粉，可快速止血",
              "数量": 3,
              "类型": "丹药"
            },
            "碎银": {
              "描述": "江湖通用的碎银子",
              "数量": 15,
              "类型": "杂物"
            }
          },
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "物品名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "描述": {
                "type": "string"
              },
              "数量": {
                "type": "number"
              },
              "类型": {
                "default": "杂物",
                "type": "string",
                "enum": [
                  "武器",
                  "防具",
                  "丹药",
                  "材料",
                  "秘籍",
                  "杂物"
                ]
              }
            },
            "required": [
              "描述",
              "数量"
            ]
          }
        }
      }
    },
    "江湖人物": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "人物名"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "身份": {
            "type": "string"
          },
          "立场": {
            "default": "未知",
            "type": "string",
            "enum": [
              "正道",
              "邪道",
              "中立",
              "未知"
            ]
          },
          "与主角关系": {
            "default": "素未谋面",
            "type": "string"
          },
          "当前位置": {
            "default": "未知",
            "type": "string"
          },
          "状态": {
            "default": "正常",
            "type": "string"
          }
        },
        "required": [
          "身份"
        ]
      }
    },
    "任务列表": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "任务名"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "类型": {
            "default": "支线",
            "type": "string",
            "enum": [
              "主线",
              "支线",
              "每日",
              "临危受命",
              "隐藏"
            ]
          },
          "说明": {
            "type": "string"
          },
          "目标": {
            "type": "string"
          },
          "奖励": {
            "type": "string"
          },
          "惩罚": {
            "default": "无",
            "type": "string"
          },
          "状态": {
            "default": "进行中",
            "type": "string",
            "enum": [
              "进行中",
              "已完成",
              "失败",
              "已放弃"
            ]
          }
        },
        "required": [
          "说明",
          "目标",
          "奖励"
        ]
      }
    }
  },
  "required": [
    "世界",
    "血玲珑",
    "主角"
  ]
}