          "content": "@@generate_before\n<%_\ndefine('current_region', getvar('stat_data.世界.当前区域', { defaults: '' }));\ndefine('current_scene', getvar('stat_data.世界.当前场景', { defaults: '' }));\ndefine('story_stage', getvar('stat_data.世界.剧情阶段', { defaults: '降临期' }));\ndefine('goddess_corruption', getvar('stat_data.世界.女神污染度', { defaults: 0 }));\ndefine('player_level', getvar('stat_data.主角.等级', { defaults: 1 }));\ndefine('glitch_tier', getvar('stat_data.主角.邪道等级', { defaults: 0 }));\ndefine('corruption', getvar('stat_data.主角.侵蚀度', { defaults: 0 }));\ndefine('silvia_affection', getvar('stat_data.西尔维娅.好感度', { defaults: 0 }));\ndefine('silvia_state', getvar('stat_data.西尔维娅.状态', { defaults: '未相遇' }));\ndefine('ilya_affection', getvar('stat_data.伊莉雅.好感度', { defaults: 0 }));\ndefine('ilya_state', getvar('stat_data.伊莉雅.状态', { defaults: '未相遇' }));\ndefine('chloe_affection', getvar('stat_data.克洛伊.好感度', { defaults: 0 }));\ndefine('chloe_state', getvar('stat_data.克洛伊.状态', { defaults: '未相遇' }));\ndefine('mira_affection', getvar('stat_data.米拉.好感度', { defaults: 0 }));\ndefine('mira_state', getvar('stat_data.米拉.状态', { defaults: '未相遇' }));\ndefine('freya_affection', getvar('stat_data.弗蕾亚.好感度', { defaults: 0 }));\ndefine('freya_state', getvar('stat_data.弗蕾亚.状态', { defaults: '未相遇' }));\ndefine('nia_affection', getvar('stat_data.妮娅.好感度', { defaults: 0 }));\ndefine('nia_state', getvar('stat_data.妮娅.状态', { defaults: '未相遇' }));\ndefine('carmilla_affection', getvar('stat_data.卡米拉.好感度', { defaults: 0 }));\ndefine('carmilla_state', getvar('stat_data.卡米拉.状态', { defaults: '未相遇' }));\ndefine('siren_affection', getvar('stat_data.深潜者.好感度', { defaults: 0 }));\ndefine('siren_state', getvar('stat_data.深潜者.状态', { defaults: '未相遇' }));\ndefine('martha_affection', getvar('stat_data.玛莎.好感度', { defaults: 0 }));\ndefine('martha_state', getvar('stat_data.玛莎.状态', { defaults: '未相遇' }));\n_%>\n",
