    "希尔薇": {
      "default": {},
      "type": "object",
      "properties": {
        "物品栏": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "物品名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "描述": {
                "type": "string"
              },
              "数量": {
                "type": "number"
              }
            },
            "required": [
              "描述",
              "数量"
            ]
          }
        }
      }
    }
  }
}