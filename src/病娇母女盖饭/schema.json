{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "type": "object",
      "properties": {
        "当前时间": {
          "type": "string"
        },
        "当前地点": {
          "type": "string"
        },
        "近期事务": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "事务名"
          },
          "additionalProperties": {
            "type": "string",
            "description": "事务描述"
          }
        }
      },
      "required": [
        "当前时间",
        "当前地点",
        "近期事务"
      ]
    },
    "诗雨": {
      "type": "object",
      "properties": {
        "依存度": {
          "type": "number"
        },
        "病娇度": {
          "type": "number"
        },
        "嫉妒值": {
          "type": "number"
        },
        "心情": {
          "type": "string",
          "enum": [
            "平静",
            "焦虑",
            "兴奋",
            "愤怒",
            "悲伤",
            "甜蜜"
          ]
        },
        "着装": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "enum": [
              "上装",
              "下装",
              "内衣",
              "袜子",
              "饰品"
            ]
          },
          "additionalProperties": {
            "type": "string",
            "description": "服装描述"
          },
          "required": [
            "上装",
            "下装",
            "内衣",
            "袜子",
            "饰品"
          ]
        },
        "当前行为": {
          "type": "string"
        }
      },
      "required": [
        "依存度",
        "病娇度",
        "嫉妒值",
        "心情",
        "着装",
        "当前行为"
      ]
    },
    "婉清": {
      "type": "object",
      "properties": {
        "依存度": {
          "type": "number"
        },
        "病娇度": {
          "type": "number"
        },
        "嫉妒值": {
          "type": "number"
        },
        "心情": {
          "type": "string",
          "enum": [
            "平静",
            "焦虑",
            "兴奋",
            "愤怒",
            "悲伤",
            "甜蜜"
          ]
        },
        "着装": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "enum": [
              "上装",
              "下装",
              "内衣",
              "袜子",
              "饰品"
            ]
          },
          "additionalProperties": {
            "type": "string",
            "description": "服装描述"
          },
          "required": [
            "上装",
            "下装",
            "内衣",
            "袜子",
            "饰品"
          ]
        },
        "当前行为": {
          "type": "string"
        }
      },
      "required": [
        "依存度",
        "病娇度",
        "嫉妒值",
        "心情",
        "着装",
        "当前行为"
      ]
    },
    "母女关系": {
      "type": "object",
      "properties": {
        "竞争指数": {
          "type": "number"
        },
        "当前优势方": {
          "type": "string",
          "enum": [
            "无",
            "诗雨",
            "婉清",
            "僵持"
          ]
        },
        "当前事件": {
          "type": "string"
        }
      },
      "required": [
        "竞争指数",
        "当前优势方",
        "当前事件"
      ]
    },
    "回忆": {
      "default": {},
      "type": "object",
      "properties": {
        "诗雨": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "回忆名"
          },
          "additionalProperties": {
            "default": false,
            "type": "boolean"
          }
        },
        "婉清": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "回忆名"
          },
          "additionalProperties": {
            "default": false,
            "type": "boolean"
          }
        },
        "主角": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "回忆名"
          },
          "additionalProperties": {
            "default": false,
            "type": "boolean"
          }
        }
      }
    },
    "主角": {
      "type": "object",
      "properties": {
        "学业": {
          "default": {},
          "type": "object",
          "properties": {
            "专业": {
              "default": "工商管理",
              "type": "string"
            },
            "年级": {
              "default": "大二",
              "type": "string"
            },
            "期末进度": {
              "default": 45,
              "type": "number"
            },
            "实习状态": {
              "default": "收到offer",
              "type": "string",
              "enum": [
                "未申请",
                "已投递",
                "面试中",
                "收到offer",
                "已接受",
                "已拒绝"
              ]
            }
          }
        },
        "社交": {
          "default": {},
          "type": "object",
          "properties": {
            "社团": {
              "default": "摄影社",
              "type": "string"
            },
            "暧昧对象": {
              "default": "",
              "type": "string"
            }
          }
        },
        "日程": {
          "default": {},
          "type": "object",
          "properties": {
            "今日": {
              "default": "",
              "type": "string"
            },
            "明日": {
              "default": "",
              "type": "string"
            }
          }
        },
        "主线任务": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "任务名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "类型": {
                "type": "string",
                "enum": [
                  "主线",
                  "支线",
                  "日常",
                  "临危受命"
                ]
              },
              "状态": {
                "type": "string",
                "enum": [
                  "未开始",
                  "进行中",
                  "已完成",
                  "已失败"
                ]
              },
              "说明": {
                "type": "string"
              },
              "目标": {
                "type": "string"
              },
              "奖励": {
                "default": "",
                "type": "string"
              },
              "惩罚": {
                "default": "",
                "type": "string"
              }
            },
            "required": [
              "类型",
              "状态",
              "说明",
              "目标"
            ]
          }
        },
        "物品栏": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "物品名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "描述": {
                "type": "string"
              },
              "数量": {
                "type": "number"
              }
            },
            "required": [
              "描述",
              "数量"
            ]
          }
        }
      },
      "required": [
        "物品栏"
      ]
    }
  },
  "required": [
    "世界",
    "诗雨",
    "婉清",
    "母女关系",
    "主角"
  ]
}